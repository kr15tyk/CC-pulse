# =============================================================
# CC PULSE — Local Development Environment Variables
# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# Usage (local):
#   cp .env.example .env
#   # edit .env
#   export $(cat .env | xargs) && python main.py
#
# Or install python-dotenv and add to main.py:
#   from dotenv import load_dotenv; load_dotenv()
# =============================================================

# ── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
CC_LOG_LEVEL=INFO

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
CC_SMTP_HOST=smtp.gmail.com
CC_SMTP_PORT=587
CC_EMAIL_USERNAME=your-sender@gmail.com
# Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
CC_EMAIL_PASSWORD=your-app-password-here
CC_EMAIL_FROM=CC Pulse <your-sender@gmail.com>
# Comma-separated list of recipient email addresses
CC_EMAIL_RECIPIENTS=you@example.com,colleague@example.com

# ── Webex Notifications ───────────────────────────────────────────────────────
# Set both values to enable real-time keyword alerts in a Webex Space.
# Leave empty to disable Webex notifications.
#
# Setup steps:
#   1. Go to https://developer.webex.com -> My Webex Apps -> Create a New App -> Bot
#   2. Name your bot (e.g. "cc-pulse-bot") and click Add Bot
#   3. Copy the Bot Token shown (it is only displayed once)
#   4. Add the bot to the Webex Space where you want alerts (@mention it)
#   5. Get the Room ID via https://developer.webex.com/docs/api/v1/rooms/list-rooms
#
CC_WEBEX_BOT_TOKEN=your-webex-bot-token-here
CC_WEBEX_ROOM_ID=your-webex-room-id-here

# ── GitHub Actions secrets (for reference) ────────────────────────────────────
# These are the secret names to add at:
#   Repo -> Settings -> Secrets and variables -> Actions -> New repository secret
#
#   CC_EMAIL_PASSWORD      <- same as above
#   CC_WEBEX_BOT_TOKEN     <- same as above
#   CC_WEBEX_ROOM_ID       <- same as above
#   CC_EMAIL_USERNAME      <- sender address
#   CC_EMAIL_RECIPIENTS    <- comma-separated recipients
